<?xml version="1.0"?>
<!DOCTYPE game_objects SYSTEM "game_objects.dtd">

<!-- TODO: Nodes need to be changed from things like 'max_health' 
           to property name='max_health.'

		   Complete DTD.
-->

<game_objects>
	<game_object name='Shake'>
		<base>
			<class>Shake</class>
			<states>
				<!-- ***One problem with defining the states
						externally is that they contain hard coded
						transitions. -->
				<state>Global</state>
				<state>Initialize</state>
				<state>Idle</state>
				<state>Walking</state>
				<state>Attack_Start</state>
				<state>Attack_Finish</state>
				<state>Hit</state>
				<state>Dead</state>
			</states>
			<attributes>
				<!-- This is our default set of attributes.
					 To create variations, we will extend/override
					 what is here. -->
				<max_health>100</max_health>
				<normal_speed>4</normal_speed>
				<powerup_speed>6</powerup_speed>
				<knockback_speed>3</knockback_speed>
				<normal_HitCoefficient>10</normal_HitCoefficient>
				<powerup_HitCoefficient>100</powerup_HitCoefficient>
				<invincible_damage>5000</invincible_damage>
				<attacks>
					<attack>
						<start_suffix>attack_ready</start_suffix>
						<projectile>0</projectile><!-- 1 = true, 0 = false -->
						<max_range>0</max_range>
						<min_range>0</min_range>
						<velocity>0</velocity>
						<normal_damage>100</normal_damage>
						<powerup_damage>100</powerup_damage>
						<normal_AttackCoefficient>50</normal_AttackCoefficient>
					</attack>
				</attacks>
			</attributes>
		</base>
		<extensions>
			<!-- Extensions add on to the various nodes defined in 'base' by mirroring
				 the structure of 'base,' but either replacing nodes, or adding new ones.
				 A new/changed node must have the 'type' attribute with a value of 'overlay,'
				 replace,' or 'insert.'

				 'overlay' - only change the exact node that differs.
				 'insert' - add this node to what already exists. 
			-->
			<EASY></EASY>
			<NORMAL>
				<attributes>
					<normal_speed>6</normal_speed>
				</attributes>
			</NORMAL>
			<HARD>
				<attacks>
					<attack>
						<start_suffix>attack_ready</start_suffix>
						<projectile>0</projectile><!-- 1 = true, 0 = false -->
						<max_range>0</max_range>
						<min_range>0</min_range>
						<velocity>0</velocity>
						<normal_damage>100</normal_damage>
						<powerup_damage>100</powerup_damage>
						<normal_AttackCoefficient>50</normal_AttackCoefficient>
					</attack>
				</attacks>
			</HARD>
		</extensions>
	</game_object>
</game_objects>


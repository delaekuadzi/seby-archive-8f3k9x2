<?xml version="1.0"?>
<!DOCTYPE states SYSTEM "game_states.dtd">

<!-- TODO: Allow more complex conditionals. Instead of
	       simply calling a function, specify a property
		   and a test value.
-->

<states>
	<state name='global'>
		<event name='onMessage'>
			<actions>
				<action name='processMessage' />
			</actions>
		</event>
	</state>
	<state name='init'>
		<event name='onEnter'>
			<actions>
				<action name='Initialize' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions />
			<transitions>
				<transition state='idle' />
			</transitions>
		</event>
	</state>
	<state name='idle'>
		<event name='onEnter'>
			<actions>
				<action name='PlayAnimation' args='idle'/>
				<action name='SetVelocity' args='0, 0' />
			</actions>
		</event>
		<event name='onUpdate'>
		</event>
	</state>
	<state name='walking'>
		<event name='onEnter'>
			<actions>
				<action name='startWalk' />
			</actions>
		</event>
		<event name='onMessage'>
			<actions>
				<action name='walking_handleMessage' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='walking' />
			</actions>
		</event>
		<event name='onExit'>
		</event>
	</state>
	<state name='attacking'>
		<event name='onEnter'>
			<actions>
				<action name='PlayAnimation' args='hit' />
				<action name='SetVelocity' args='0, 0' />
			</actions>
		</event>
		<event name='onMessage'>
			<actions>
				<action name='SaveAction' />
  			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='attacking' />
			</actions>
		</event>
	</state>
	<state name='ducking'>
		<event name='onEnter'>
			<actions>
				<action name='PlayAnimation' args='bend'/>
				<action name='SetVelocity' args='0, 0' />
			</actions>
		</event>
		<event name='onMessage'>
			<actions>
				<action name='SaveAction' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='ducking' />
			</actions>
		</event>
	</state>
	<state name='jumping'>
		<event name='onEnter'>
			<actions>
				<action name='PlayAnimation' args='bend' />
				<action name='SetVelocity' args='null, -10' />
			</actions>
		</event>
		<event name='onMessage'>
			<actions>
				<action name='SaveAction' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='jumping' />
			</actions>
		</event>
	</state>
</states>
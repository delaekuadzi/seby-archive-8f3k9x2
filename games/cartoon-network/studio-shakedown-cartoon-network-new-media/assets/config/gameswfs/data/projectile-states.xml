<?xml version="1.0"?>
<!DOCTYPE states SYSTEM "game_states.dtd">

<states>
	<state name='global'>
		<event name='onMessage'>
			<actions>
				<action name='handleMessage' />
			</actions>
		</event>
	</state>
	<state name='init'>
		<event name='onEnter'>
			<actions>
				<action name='Initialize' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions />
			<transitions>
				<transition state='idle' />
			</transitions>
		</event>
	</state>
	<state name='idle'>
		<event name='onEnter'>
			<actions>
				<action name='SetActive' args='true' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='Fight_Gravity' />
				<action name='CheckForCollisions' args='colliders' />
			</actions>
		</event>
	</state>
</states>
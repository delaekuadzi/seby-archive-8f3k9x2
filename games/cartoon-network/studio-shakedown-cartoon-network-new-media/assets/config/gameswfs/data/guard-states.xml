<?xml version="1.0"?>
<!DOCTYPE states SYSTEM "game_states.dtd">

<states>
	<state name='global'>
		<event name='onMessage'>
			<actions>
				<action name='handleMessage' />
			</actions>
		</event>
	</state>
	<state name='init'>
		<event name='onEnter'>
			<actions>
				<action name='Initialize' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions />
			<transitions>
				<transition state='idle' />
			</transitions>
		</event>
	</state>
	<state name='idle'>
		<event name='onEnter'>
			<actions />
		</event>
	</state>
	<state name='walking'>
		<event name='onEnter'>
			<actions>
				<action name='startWalk' />
				<action name='PlayAnimation' args='walk'/>
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='walking' />
				<action name='UpdateAnimation' />
				<action name='draw' />
			</actions>
			<transitions>
				<transition condition='SeesEnemy' state='chase' />
			</transitions>
		</event>
		<event name='onExit'>
		</event>
	</state>

	<state name='searching'>
		<event name='onEnter'>
			<actions>
				<action name='PlayAnimation' args='scan'/>
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='UpdateAnimation' />
				<action name='draw' />
				<action name='CheckDelay' args='1,walking' />
			</actions>
			<transitions>
				<transition condition='SeesEnemy' state='target_spotted' />
			</transitions>
		</event>
		<event name='onExit'>
		</event>
	</state>

	<state name='target_spotted'>
		<event name='onUpdate'>
			<actions>
				<action name='UpdateAnimation' />
				<action name='CheckDelay' args='1,chase' />
			</actions>
		</event>
	</state>

	<state name='change_floors'>
		<event name='onEnter'>
			<actions>
				<action name='SetGoal' args='elevator' />
				<action name='FaceGoal' args='walk' />
				<action name='SetVelocityTowardsGoal' />
				<action name='PlayAnimation' args='walk'/>
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='UpdateAnimation' />
				<action name='draw' />
			</actions>
			<transitions>
				<transition condition='SeesEnemy' state='chase' />
				<transition condition='MoveToGoal' state='call_elevator' />
			</transitions>
		</event>
		<event name='onExit'>
		</event>
	</state>
	<state name='call_elevator'>
		<event name='onEnter'>
			<actions>
				<action name='UseDoor' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='UseDoor' />
			</actions>
			<transitions>
				<transition condition='SeesEnemy' state='chase' />
			</transitions>
		</event>
		<event name='onExit'>
		</event>
	</state>

	<state name='entering_elevator'>
		<event name='onEnter'>
			<actions>
				<action name='PlayAnimation' args='enter' />
				<action name='SetVelocity' args='0,0' />
                <action name='setTransportLock' args='true'/>
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='CheckForAnimationComplete' args='ride_elevator' />
			</actions>
		</event>
		<event name='onExit'>
			<actions>
				<!-- <action name='SetVisible' args='false' /> -->
			</actions>
		</event>
	</state>
	<state name='ride_elevator'>
		<event name='onEnter'>
			<actions>
				<action name='SetVisible' args='false' />
				<action name='TellElevatorReady' />
				<action name='MoveUnderDoor' />
				<action name='SetGoal' args='floor' />
				<action name='SetVelocityTowardsGoal' />
				<action name='setMap' args='null' />
			</actions>
		</event>
		<event name='onMessage' >
			<actions>
				<action name='riding_handleMessage' />
		    </actions>
        </event>
		<event name='onUpdate'>
			<actions>
				<action name='draw' />
			</actions>
			<transitions>
				<transition condition='MoveToGoal' state='exiting_elevator' />
			</transitions>
		</event>
	</state>
	<state name='exiting_elevator'>
		<event name='onEnter'>
			<actions>
				<action name='PlayAnimation' args='exit' />
				<action name='SetVisible' args='true' />
				<action name='TellElevatorReady' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='CheckForAnimationComplete' args='searching' />
			</actions>
		</event>
		<event name='onExit'>
			<actions>
				<action name='exitDoor'/>
				<action name='TellElevatorExit' />
                <action name='setTransportLock' args='false' />
			</actions>
		</event>
	</state>


	<state name='exiting_door'>
		<event name='onEnter'>
			<actions>
				<action name='PlayAnimation' args='exit' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='CheckForAnimationComplete' args='change_floors' />
			</actions>
		</event>
		<event name='onExit'>
			<actions>
				<action name='exitDoor' />
				<action name='OpenNewDoor' />
			</actions>
		</event>
	</state>

	<state name='chase'>
		<event name='onEnter'>
			<actions>
				<action name='ShowAlert' />
				<action name='PlayAnimation' args='walk'/>
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='SetGoal' args='enemy' />
				<action name='FaceGoal' args='walk' />
				<action name='SetVelocityTowardsGoal' />
				<action name='MoveToGoal' />
				<action name='UpdateAnimation' />
				<action name='draw' />
			</actions>
			<transitions>
				<transition condition='SeesEnemy' result='false' state='searching' />
				<transition condition='WithinAttackRange' args='85' state='attack_bomb_start' />
				<transition condition='WithinAttackRange' args='200' state='attack_laser_start' />
				<transition condition='WithinAttackRange' args='300' state='attack_missile_start' />
			</transitions>
		</event>
		<event name='onExit'>
		</event>
	</state>
	<state name='attack_missile_start'>
		<event name='onEnter'>
			<actions>
				<action name='PlayAnimation' args='arm_missile'/>
				<action name='PlaySound' args='sfx_security_attack_readyrocket'/>
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='UpdateAnimation' />
				<action name='CheckDelay' args='2,attack_missile' />
			</actions>
		</event>
	</state>
	<state name='attack_missile'>
		<event name='onEnter'>
			<actions>
				<action name='Launch' args='1'/>
				<action name='PlaySound' args='sfx_security_attack_missle'/>
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='CheckDelay' args='1,attack_missile_finish' />
			</actions>
		</event>
	</state>
	<state name='attack_missile_finish'>
		<event name='onUpdate'>
			<actions>
				<action name='CheckDelay' args='1,walking' />
			</actions>
		</event>
	</state>
	<state name='attack_bomb_start'>
		<event name='onEnter'>
			<actions>
				<action name='PlayAnimation' args='bomb'/>
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='CheckForAnimationComplete' args='attack_bomb' />
			</actions>
		</event>
	</state>
	<state name='attack_bomb'>
		<event name='onEnter'>
			<actions>
				<action name='Launch' args='0'/>
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='CheckDelay' args='1,attack_bomb_finish' />
			</actions>
		</event>
	</state>
	<state name='attack_bomb_finish'>
		<event name='onUpdate'>
			<actions>
				<action name='CheckDelay' args='1,walking' />
			</actions>
		</event>
	</state>
	<state name='attack_laser_start'>
		<event name='onEnter'>
			<actions>
				<action name='PlaySound' args='sfx_security_readylaser'/>
				<action name='PlayAnimation' args='laser'/>
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='CheckForAnimationComplete' args='attack_laser' />
			</actions>
		</event>
	</state>
	<state name='attack_laser'>
		<event name='onEnter'>
			<actions>
				<action name='PlaySound' args='sfx_security_attack_laser'/>
				<action name='Launch' args='2'/>
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='CheckDelay' args='1,attack_laser_finish' />
			</actions>
		</event>
	</state>
	<state name='attack_laser_finish'>
		<event name='onUpdate'>
			<actions>
				<!--<action name='CheckForAnimationComplete' args='attack_missile' />-->
				<action name='CheckDelay' args='1,walking' />
			</actions>
		</event>
	</state>
	<state name='dying'>
		<event name='onEnter'>
			<actions>
				<action name='PlayAnimation' args='dead'/>
			</actions>
		</event>
		<event name='onMessage'>
			<actions>
				<action name='dying_handleMessage' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='CheckForAnimationComplete' args='dead' />
			</actions>
		</event>
	</state>
	<state name='dead'>
		<event name='onEnter'>
			<actions>
				<action name='die' />
			</actions>
		</event>
	</state>
</states>
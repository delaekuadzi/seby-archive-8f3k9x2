<?xml version="1.0"?>
<!DOCTYPE states SYSTEM "game_states.dtd">

<states>
	<state name='global'>
		<event name='onMessage'>
			<actions>
				<action name='handleMessage' />
			</actions>
		</event>
	</state>
	<state name='init'>
		<event name='onEnter'>
			<actions>
				<action name='Initialize' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='Elevator_Intro' />
			</actions>
			<transitions>
				<transition state='idle' />
			</transitions>
		</event>
	</state>
	<state name='idle'>
		<event name='onUpdate'>
			<actions/>	
			<transitions>
				<transition condition='CheckForPassenger' state='transporting' />
				<transition condition='CheckRequests' state='change_floors' />
			</transitions>
		</event>
	</state>
	<state name='change_floors'>
		<event name='onEnter'>
			<actions>
				<action name='SetGoal' />
				<action name='SetVelocityTowardsGoal' />
				<action name='ToggleDoor' />
				<action name='setCurrentFloor' args='null' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions />
			<transitions>
				<transition condition='MoveToGoal' state='arrive' />
			</transitions>
		</event>
		<event name='onExit'>
		</event>
	</state>
	<state name='arrive'>
		<event name='onEnter'>
			<actions>
				<action name='ArriveForPickup' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='CheckDelay' args='4,idle' />
			</actions>
			<transitions>
				<transition condition='CheckForPassenger' state='transporting' />
			</transitions>
		</event>
		<event name='onExit'>
		</event>
	</state>
	<state name='transporting'>
		<event name='onUpdate'>
			<actions />
			<transitions>
				<transition condition='CheckForPassenger' result='false' state='idle' />
			</transitions>
		</event>
		<event name='onExit'>
		</event>
	</state>
</states>
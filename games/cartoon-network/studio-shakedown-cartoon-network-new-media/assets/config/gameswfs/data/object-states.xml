<?xml version="1.0"?>
<!DOCTYPE states SYSTEM "game_states.dtd">

<states>
	<state name='global'>
		<event name='onMessage'>
			<actions>
				<action name='handleMessage' />
			</actions>
		</event>
	</state>
	<state name='init'>
		<event name='onEnter'>
			<actions>
				<action name='Initialize' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions />
			<transitions>
				<transition state='idle' />
			</transitions>
		</event>
	</state>
	<state name='idle'>
		<event name='onEnter'>
			<actions>
				<action name='Set_Group_Active' args='colliders' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>
				<action name='CheckForCollisions' args='colliders' />
			</actions>
		</event>
	</state>
	<state name='alert_on'>
		<event name='onEnter'>
			<actions>
				<action name='PlayAnimation' args='blink'/>
				<action name='Set_FSM_Update' args='true' />
			</actions>
		</event>
		<event name='onUpdate'>
			<actions>				
				<action name='UpdateAnimation' />
				<action name='CheckDelay' args='10,idle' />
			</actions>
		</event>
		<event name='onExit'>
			<actions>				
				<action name='Set_FSM_Update' args='false' />
				<action name='PlayAnimation' args='idle' />
			</actions>
		</event>
	</state>
</states>